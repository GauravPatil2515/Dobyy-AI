# ─── Server-side only (Vercel env vars — never prefix with VITE_) ───
# Groq API key — get from https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# OpenRouter API key — get from https://openrouter.ai/keys
OPENROUTER_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx

# Your production domain — used for CORS and HTTP-Referer
# Example: https://dobyy-ai.vercel.app  (no trailing slash)
ALLOWED_ORIGIN=https://your-app.vercel.app

# ─── Client-side Firebase config (safe to expose — secured via Firestore Rules) ───
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-app.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-app.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx
